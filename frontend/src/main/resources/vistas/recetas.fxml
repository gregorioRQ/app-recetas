<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.frontend.controlador.RecetasController" prefWidth="800" prefHeight="600">
   <children>
      <Label text="Mis Recetas" style="-fx-font-size: 24px; -fx-font-weight: bold;" />
      <GridPane fx:id="recetasGrid" hgap="20" vgap="20">
      <padding>
            <Insets top="20.0" right="20.0" bottom="20.0" left="20.0" />
         </padding>
         <!-- Las tarjetas de recetas se generarán dinámicamente aquí -->
      </GridPane>

      <HBox alignment="CENTER" spacing="10.0">
         <children>
            <Button text="Volver al inicio" onAction="#volverAlInicio" />
         </children>
      </HBox>
   </children>
</VBox>